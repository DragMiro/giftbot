# Telegram Bot API (один токен на весь сервер)
BOT_TOKEN=

# Каталог: SQLite + зашифрованные сессии (не .session файлы)
DATA_DIR=data

# ОБЯЗАТЕЛЬНО для production — отдельный ключ (не BOT_TOKEN!)
# python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Опционально: whitelist Telegram user id через запятую
ALLOWED_USER_IDS=

GIFT_SEND_DELAY=2.0
